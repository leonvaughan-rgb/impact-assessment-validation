    "processes": ["Customer profiling", "Campaign targeting", "Monthly reporting"],
    "geographies": ["United Kingdom", "European Union"]
  },
  "data": {
    "categories": ["Contact details", "Usage behaviour", "Transaction history"],
    "subjects": "Existing and prospective customers",
    "retention": "24 months from last interaction",
    "transfers": "No third-country transfers planned"
  },
  "risks": {
    "items": [
      {
        "risk_id": "R1",
        "description": "Unauthorised access to aggregated customer profiles",
        "likelihood": 3,
        "impact": 4,
        "inherent_score": 12
      },
      {
        "risk_id": "R2",
        "description": "Excessive data collection beyond stated purpose",
        "likelihood": 2,
        "impact": 3,
        "inherent_score": 6
      }
    ]
  },
  "mitigations": {
